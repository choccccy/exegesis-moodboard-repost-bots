# ---------------------------------------------------------------------------
# Secret/config template. Generate the real .env at deploy time with:
#
#     op inject -i .env.tmpl -o .env
#
# The 1Password secret references below resolve against your vault. Adjust the
# vault/item/field names to match what you create. Non-secret values can be
# edited inline. NEVER commit the generated .env (it is .gitignored).
# ---------------------------------------------------------------------------

# --- Discord (secret) ---
# Bot token from https://discord.com/developers/applications -> Bot -> Reset Token
DISCORD_BOT_TOKEN="op://Private/mcy4qenzfghlnn4kqgpnimpuxq/credential"

# --- Board configuration (non-secret; edit inline) ---
# One board per moodboard channel. v1 starts with a single board.
# Format: a JSON list of board objects (kept as one line for env compatibility).
#   name              : human label for the board
#   discord_guild_id  : server (guild) ID
#   discord_channel_id: the single channel to watch
#   nsfw              : true if every post from this board is sexual/NSFW
#   curator_role_ids  : Discord role IDs allowed to answer the bot's requests
#   bluesky_handle    : Bluesky account handle for this board (not secret)
BOARDS_JSON='[{"name":"robot-posting","discord_guild_id":1413241899325718582,"discord_channel_id":1413255644869427322,"nsfw":false,"curator_role_ids":[1517006033472454687],"bluesky_handle":"robots.exegesis.space","tags":["robot-posting"]},{"name":"robot-fucking","discord_guild_id":1413241899325718582,"discord_channel_id":1413255876327772354,"nsfw":true,"curator_role_ids":[1517006033472454687],"bluesky_handle":"xxx-robots.exegesis.space","tags":["robot-fucking"]},{"name":"weird-wheels","discord_guild_id":1413241899325718582,"discord_channel_id":1413257242446397562,"nsfw":false,"curator_role_ids":[1517006033472454687],"bluesky_handle":"vehicles.exegesis.space","tags":["weird-wheels"]},{"name":"doohickey-posting","discord_guild_id":1413241899325718582,"discord_channel_id":1438649057986871406,"nsfw":false,"curator_role_ids":[1517006033472454687],"bluesky_handle":"doohickeys.exegesis.space","tags":["doohickey-posting"]},{"name":"nerd-tv","discord_guild_id":1413241899325718582,"discord_channel_id":1413256258563211315,"nsfw":false,"curator_role_ids":[1517006033472454687],"bluesky_handle":"tv.exegesis.space","tags":["nerd-tv"]}]'

# --- Bluesky app passwords (secret) ---
# One per board. Named BSKY_APP_PASSWORD_<BOARD_NAME_UPPER> where the board
# name is uppercased with hyphens replaced by underscores.
# Create app passwords at https://bsky.app/settings/app-passwords
# Store each in 1Password; reference it below using the same format as the other secrets above.
# The matching bluesky_handle goes in BOARDS_JSON (not secret).
BSKY_APP_PASSWORD_ROBOT_POSTING="op://Private/exegesis robots/app password"
BSKY_APP_PASSWORD_ROBOT_FUCKING="op://Private/exegesis xxx-robots/app password"
BSKY_APP_PASSWORD_WEIRD_WHEELS="op://Private/exegesis vehicles/app password"
BSKY_APP_PASSWORD_DOOHICKEY_POSTING="op://Private/exegesis doohickeys/app password"
BSKY_APP_PASSWORD_NERD_TV="op://Private/exegesis tv/app password"

# --- Trigger ---
# Unicode butterfly. Override only if you intentionally use a different emoji.
TRIGGER_EMOJI="🦋"

# --- Storage / runtime (non-secret) ---
DATA_DIR="/data"
DATABASE_URL="sqlite+aiosqlite:////data/db/bot.db"
# Refuse new attachment downloads once free space drops below this (MB).
STORAGE_MIN_FREE_MB="500"
LOG_LEVEL="INFO"

# --- Offline catch-up ---
# On startup, scan recent channel history and ingest any message that already
# has a 🦋 reaction but no submission yet (reactions added while the bot was
# down). Bounded by a lookback window and a per-channel message cap.
CATCHUP_ENABLED="true"
CATCHUP_LOOKBACK_HOURS="168"
CATCHUP_MAX_MESSAGES="500"
