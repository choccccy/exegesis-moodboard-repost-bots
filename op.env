# Environment file for use with `op run --env-file op.env -- <command>`.
# Secret values use 1Password URI syntax: op://VAULT/ITEM/FIELD
# Non-secret values are plain text and edited inline.
# Safe to commit — no real secrets here, only references.

# --- Secrets ---
DISCORD_BOT_TOKEN="op://Private/mcy4qenzfghlnn4kqgpnimpuxq/credential"

BSKY_APP_PASSWORD_ROBOT_POSTING="op://Private/exegesis robots/app password"
BSKY_APP_PASSWORD_ROBOT_FUCKING="op://Private/exegesis xxx-robots/app password"
BSKY_APP_PASSWORD_WEIRD_WHEELS="op://Private/exegesis vehicles/app password"
BSKY_APP_PASSWORD_DOOHICKEY_POSTING="op://Private/exegesis doohickeys/app password"
BSKY_APP_PASSWORD_NERD_TV="op://Private/exegesis tv/app password"

# YouTube Data API v3 key (no OAuth - read-only metadata, 10k units/day free).
# Create at: console.cloud.google.com → APIs & Services → Credentials → API key
# Restrict the key to "YouTube Data API v3" in the console.
YOUTUBE_API_KEY="op://Private/exegesis youtube data API v3/credential"

# YouTube OAuth2 credentials for playlist writes (read-write, separate from the API key above).
# Run scripts/youtube_auth.py locally to obtain these; save to 1Password as "YouTube OAuth2".
YOUTUBE_CLIENT_ID="op://Private/YouTube OAuth2/client_id"
YOUTUBE_CLIENT_SECRET="op://Private/YouTube OAuth2/client_secret"
YOUTUBE_REFRESH_TOKEN="op://Private/YouTube OAuth2/refresh_token"
PLAYLIST_EMOJI="▶️"

# --- Board configuration ---
