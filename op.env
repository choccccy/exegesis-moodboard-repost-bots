# Environment file for use with `op run --env-file op.env -- <command>`.
# Secret values use 1Password URI syntax: op://VAULT/ITEM/FIELD
# Non-secret values are plain text and edited inline.
# Safe to commit - no real secrets here, only references.

# --- Secrets ---
DISCORD_BOT_TOKEN="op://exegesis/635ocywu2jsraat4nnylhrqixe/credential"

BSKY_APP_PASSWORD_ROBOT_POSTING="op://exegesis/exegesis robots/app password"
BSKY_APP_PASSWORD_ROBOT_FUCKING="op://exegesis/exegesis xxx-robots/app password"
BSKY_APP_PASSWORD_WEIRD_WHEELS="op://exegesis/exegesis vehicles/app password"
BSKY_APP_PASSWORD_DOOHICKEY_POSTING="op://exegesis/exegesis doohickeys/app password"
BSKY_APP_PASSWORD_NERD_TV="op://exegesis/exegesis tv/app password"

# YouTube Data API v3 key (no OAuth - read-only metadata, 10k units/day free).
# Create at: console.cloud.google.com → APIs & Services → Credentials → API key
# Restrict the key to "YouTube Data API v3" in the console.
YOUTUBE_API_KEY="op://exegesis/exegesis youtube data API v3/bzzrgfwkddmjpybiefckzgbinm"

# YouTube OAuth2 credentials for playlist writes (read-write, separate from the API key above).
# Run scripts/youtube_auth.py locally to obtain these; save to 1Password as "YouTube OAuth2".
YOUTUBE_CLIENT_ID="op://exegesis/exegesis google oauth client id/username"
YOUTUBE_CLIENT_SECRET="op://exegesis/exegesis google oauth client id/credential"
YOUTUBE_REFRESH_TOKEN="op://exegesis/exegesis google oauth client id/refresh token"

