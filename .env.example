# ── Discord ───────────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=

# ── Bluesky app passwords ─────────────────────────────────────────────────────
# One entry per board.
# Env var name = BSKY_APP_PASSWORD_<NAME_UPPERCASED_HYPHENS_TO_UNDERSCORES>
# Example for a board named "my-board":
BSKY_APP_PASSWORD_MY_BOARD=xxxx-xxxx-xxxx-xxxx

# ── Board configuration ───────────────────────────────────────────────────────
# JSON array - one object per watched Discord channel.
# See the "Configuring boards" section of the README for full field documentation.
BOARDS_JSON=[{"name":"my-board","discord_guild_id":0,"discord_channel_id":0,"nsfw":false,"curator_role_ids":[],"curator_user_ids":[],"bluesky_handle":"myboard.bsky.social","tags":[],"youtube_playlist_id":null,"display_name":"My Board"}]

# ── Trigger emoji ─────────────────────────────────────────────────────────────
TRIGGER_EMOJI=🦋

# ── Storage ───────────────────────────────────────────────────────────────────
DATA_DIR=/data
DATABASE_URL=sqlite+aiosqlite:////data/db/bot.db
# Bot pauses ingestion when free disk space falls below this value (MB)
STORAGE_MIN_FREE_MB=500

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Posting schedule ──────────────────────────────────────────────────────────
# IANA timezone name - used for QUEUE_START_HOUR and dashboard timestamps
QUEUE_TIMEZONE=America/Denver
# Hour of day (local time) to start posting each day
QUEUE_START_HOUR=12
# Posts with a source date newer than this many hours are considered "fresh"
QUEUE_FRESH_WINDOW_HOURS=72
# Max fresh posts published per board per day
QUEUE_FRESH_DAILY_CAP=6
# Max backlog posts published per board per day
QUEUE_BACKLOG_DAILY_CAP=3

# ── Offline catch-up ──────────────────────────────────────────────────────────
# On bot startup, scan channel history for 🦋 reactions the bot may have missed
CATCHUP_ENABLED=true
CATCHUP_LOOKBACK_HOURS=168
CATCHUP_MAX_MESSAGES=500

# ── Dashboard ─────────────────────────────────────────────────────────────────
# Optional. When set, queued-notice messages in Discord include a link to this URL.
DASHBOARD_URL=

# ── YouTube integration (optional) ────────────────────────────────────────────
# Read-only metadata (video titles, thumbnails) - API key only required
YOUTUBE_API_KEY=
# Playlist writes require OAuth2 credentials from Google Cloud Console
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# ── 1Password (for operators using `op run`) ──────────────────────────────────
# Instead of plain values, you can use op:// URIs in a separate op.env file
# and resolve them at runtime without writing secrets to disk:
#
#   op run --env-file op.env --no-masking -- docker compose up -d
#
# op.env follows the same format as this file; replace values with references:
#   DISCORD_BOT_TOKEN=op://Vault/Item/field
#   BSKY_APP_PASSWORD_MY_BOARD=op://Vault/Item/field
#
# op.env is listed in .gitignore - never commit it.
